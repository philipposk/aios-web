# ── Page Assistant widget ───────────────────────────────────────────────────
# URL of the running AI-OS backend.  The floating assistant widget will be
# rendered only when this is set; omit it (or leave blank) to hide the widget.
# For local development, point at the AI-OS FastAPI server:
NEXT_PUBLIC_AIOS_API_URL=http://localhost:8765
# Optional bearer token matching API_COMPANY_TOKEN in AI-OS .env.
# Leave blank if AI_COMPANY_TOKEN= (open access).
NEXT_PUBLIC_AIOS_API_TOKEN=
